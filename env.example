# Supabase 설정
# 실제 Supabase 프로젝트 URL과 anon key를 입력하세요
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 예시:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 사이트 URL
NEXT_PUBLIC_SITE_URL=https://tennisfriends.co.kr

# 웹마스터 도구 인증 코드
# 구글 Search Console - HTML 메타 태그의 content 값 또는 HTML 파일명에서 google과 .html 제거한 코드
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# 네이버 서치어드바이저 - HTML 메타 태그의 content 값 또는 HTML 파일명에서 naver와 .html 제거한 코드
NAVER_SITE_VERIFICATION=your-naver-verification-code

# 다음 검색 등록 (선택)
DAUM_SITE_VERIFICATION=your-daum-verification-code

# Bing 웹마스터 도구 (선택)
BING_SITE_VERIFICATION=your-bing-verification-code
